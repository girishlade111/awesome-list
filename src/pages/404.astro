---
import Layout from '../layouts/Layout.astro';

const suggestions = [
  { href: '/', label: 'Go Home' },
  { href: '/browse', label: 'Browse Resources' },
  { href: '/learn', label: 'Learning Hub' },
  { href: '/submit', label: 'Submit a Resource' },
];
---

<Layout 
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <section class="not-found">
    <div class="container">
      <div class="not-found-content">
        <div class="error-code">
          <span class="code-digit">4</span>
          <span class="code-digit">0</span>
          <span class="code-digit">4</span>
        </div>
        <h1>Page Not Found</h1>
        <p class="error-message">
          The page you're looking for doesn't exist or may have been moved.
        </p>
        
        <div class="suggestions">
          <p class="suggestion-title">Where would you like to go?</p>
          <div class="suggestion-links">
            {suggestions.map(suggestion => (
              <a href={suggestion.href} class="suggestion-card">
                <span class="suggestion-label">{suggestion.label}</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
        </div>

        <div class="search-help">
          <p>
            Looking for something specific? Try using the 
            <button type="button" class="search-trigger-btn" id="search-trigger-btn">search</button> 
            to find resources, tutorials, and more.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 0;
  }

  .not-found-content {
    text-align: center;
    max-width: 600px;
  }

  .error-code {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .code-digit {
    font-family: var(--font-heading);
    font-size: 6rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
  }

  .not-found-content h1 {
    margin-bottom: 16px;
  }

  .error-message {
    color: var(--text-secondary);
    font-size: 1.125rem;
    margin-bottom: 48px;
  }

  .suggestions {
    margin-bottom: 48px;
  }

  .suggestion-title {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .suggestion-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }

  .suggestion-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .suggestion-card:hover {
    border-color: var(--primary);
    transform: translateX(4px);
  }

  .suggestion-card svg {
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .suggestion-card:hover svg {
    color: var(--primary);
  }

  .search-help {
    padding: 24px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .search-help p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
  }

  .search-trigger-btn {
    background: none;
    border: none;
    color: var(--primary);
    font-weight: 600;
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
    font-size: inherit;
  }

  .search-trigger-btn:hover {
    color: var(--primary-hover);
  }

  @media (max-width: 640px) {
    .code-digit {
      font-size: 4rem;
    }

    .suggestion-links {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Trigger global search when button is clicked
  const searchBtn = document.getElementById('search-trigger-btn');
  searchBtn?.addEventListener('click', () => {
    // Try to trigger the global search
    const searchTrigger = document.getElementById('search-trigger');
    if (searchTrigger) {
      searchTrigger.click();
    } else {
      // Fallback: navigate to browse page
      window.location.href = '/browse';
    }
  });
</script>