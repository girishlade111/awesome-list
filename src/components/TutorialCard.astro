---
interface Props {
  id: string;
  title: string;
  description: string;
  difficulty: string;
  duration: string;
  category: string;
  author: string;
  url: string;
}

const { id, title, description, difficulty, duration, category, author, url } = Astro.props;

const difficultyClass = `badge-${difficulty}`;

const categoryColors: Record<string, string> = {
  'getting-started': 'linear-gradient(135deg, #6366f1 0%, #818cf8 100%)',
  'tutorials': 'linear-gradient(135deg, #22d3ee 0%, #67e8f9 100%)',
  'advanced': 'linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%)',
  'integration': 'linear-gradient(135deg, #10b981 0%, #34d399 100%)',
};

const bgGradient = categoryColors[category] || categoryColors['tutorials'];
---

<article class="tutorial-card">
  <div class="tutorial-thumbnail" style={`background: ${bgGradient}`}>
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      <path d="M8 7h8M8 11h6"/>
    </svg>
  </div>
  
  <div class="tutorial-content">
    <div class="tutorial-meta">
      <span class={`badge ${difficultyClass}`}>{difficulty}</span>
      <span class="duration">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        {duration}
      </span>
    </div>
    
    <h3 class="tutorial-title">
      <a href={url}>{title}</a>
    </h3>
    
    <p class="tutorial-description">{description}</p>
    
    <div class="tutorial-footer">
      <span class="author">By {author}</span>
    </div>
  </div>
</article>

<style>
  .tutorial-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.2s ease;
  }

  .tutorial-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow: var(--shadow-glow);
  }

  .tutorial-thumbnail {
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.9;
  }

  .tutorial-content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .tutorial-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .duration {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .tutorial-title {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .tutorial-title a {
    color: var(--text-primary);
  }

  .tutorial-title a:hover {
    color: var(--primary);
  }

  .tutorial-description {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
    flex: 1;
  }

  .tutorial-footer {
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  .author {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
</style>