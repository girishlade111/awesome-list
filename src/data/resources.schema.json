{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DevHub Resources Schema",
  "type": "object",
  "required": ["resources"],
  "properties": {
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "category", "author", "authorUrl", "tags", "url", "addedAt"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          },
          "category": {
            "type": "string",
            "enum": ["agent", "prompt", "instruction", "plugin", "workflow"]
          },
          "author": {
            "type": "string"
          },
          "authorUrl": {
            "type": "string",
            "format": "uri"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "addedAt": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}
