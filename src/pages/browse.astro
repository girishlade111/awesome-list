---
import Layout from '../layouts/Layout.astro';
import resourcesData from '../data/resources.json';
import ResourceFilter from '../components/ResourceFilter.astro';

const ITEMS_PER_PAGE = 12;
const totalPages = Math.ceil(resourcesData.resources.length / ITEMS_PER_PAGE);
---

<Layout 
  title="Browse Resources"
  description="Search and filter the complete collection of community-curated resources."
>
  <section class="browse-hero">
    <div class="container">
      <h1>Browse Resources</h1>
      <p>Find the perfect agent, prompt, instruction, or plugin for your needs</p>
      <div class="stats">
        <span class="stat-item">
          <strong>{resourcesData.resources.length}</strong> resources
        </span>
        <span class="stat-item">
          <strong>{[...new Set(resourcesData.resources.flatMap(r => r.tags))].length}</strong> tags
        </span>
        <span class="stat-item">
          <strong>{[...new Set(resourcesData.resources.map(r => r.author))].length}</strong> contributors
        </span>
      </div>
    </div>
  </section>

  <section class="browse-content section">
    <div class="container">
      <ResourceFilter resources={resourcesData.resources} />
    </div>
  </section>
</Layout>

<style>
  .browse-hero {
    padding: 80px 0 40px;
    text-align: center;
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(99, 102, 241, 0.1), transparent);
  }

  .browse-hero h1 {
    margin-bottom: 12px;
  }

  .browse-hero p {
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .stat-item strong {
    color: var(--primary);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .browse-content {
    min-height: 60vh;
  }
</style>