{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DevHub Resources",
  "description": "Schema for validating DevHub resources data",
  "type": "object",
  "properties": {
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "category", "author", "authorUrl", "tags", "url", "addedAt"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "Unique identifier in kebab-case"
          },
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          },
          "category": {
            "type": "string",
            "enum": ["agent", "prompt", "instruction", "plugin", "workflow"]
          },
          "author": {
            "type": "string",
            "minLength": 1
          },
          "authorUrl": {
            "type": "string",
            "format": "uri"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "minItems": 1,
            "maxItems": 10
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "github": {
            "type": "string",
            "format": "uri"
          },
          "addedAt": {
            "type": "string",
            "format": "date"
          },
          "stars": {
            "type": "integer",
            "minimum": 0
          },
          "featured": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "tutorials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "difficulty", "duration", "category", "author"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 150
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          },
          "difficulty": {
            "type": "string",
            "enum": ["beginner", "intermediate", "advanced"]
          },
          "duration": {
            "type": "string",
            "pattern": "^[0-9]+ (min|minutes|hour|hours)$"
          },
          "category": {
            "type": "string",
            "enum": ["getting-started", "tutorials", "advanced", "best-practices", "case-studies", "integration"]
          },
          "author": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["resources"],
  "additionalProperties": false
}
