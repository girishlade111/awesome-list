---
import Layout from '../../layouts/Layout.astro';
import resourcesData from '../../data/resources.json';

export async function getStaticPaths() {
  return resourcesData.resources.map((resource) => ({
    params: { id: resource.id },
    props: { resource },
  }));
}

const { resource } = Astro.props;

// Find other resources from same category
const related = resourcesData.resources
  .filter(r => r.category === resource.category && r.id !== resource.id)
  .slice(0, 3);
---

<Layout title={resource.title} description={resource.description}>
  <div class="resource-detail container">
    <nav class="breadcrumb">
      <a href="/browse">Directory</a>
      <span class="separator">/</span>
      <span class="current">{resource.title}</span>
    </nav>

    <div class="resource-layout">
      <div class="resource-main">
        <header class="resource-header">
          <div class="resource-meta-top">
            <span class={`badge badge-${resource.category}`}>{resource.category}</span>
            <span class="resource-date">Added on {resource.addedAt}</span>
          </div>
          <h1>{resource.title}</h1>
          <p class="resource-description">{resource.description}</p>
          
          <div class="resource-actions">
            <a href={resource.url} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
              Visit Resource
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
            <button class="btn btn-secondary btn-lg share-btn" data-url={Astro.url}>
              Share
            </button>
          </div>
        </header>

        <section class="resource-details-section">
          <h3>Information</h3>
          <div class="details-grid">
            <div class="detail-item">
              <span class="detail-label">Author</span>
              <a href={resource.authorUrl} target="_blank" rel="noopener" class="author-link">
                {resource.author}
              </a>
            </div>
            <div class="detail-item">
              <span class="detail-label">Tags</span>
              <div class="tag-list">
                {resource.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            <div class="detail-item">
              <span class="detail-label">Category</span>
              <span class="category-name">{resource.category}</span>
            </div>
          </div>
        </section>

        {related.length > 0 && (
          <section class="related-section">
            <h3>Similar Resources</h3>
            <div class="related-grid">
              {related.map(item => (
                <a href={`/resource/${item.id}`} class="related-card card">
                  <span class={`badge badge-${item.category}`}>{item.category}</span>
                  <h4>{item.title}</h4>
                  <p>{item.description.substring(0, 80)}...</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      <aside class="resource-sidebar">
        <div class="sidebar-card card">
          <h4>Report Issue</h4>
          <p>Found a broken link or incorrect information?</p>
          <a href="https://github.com/issues" class="btn btn-ghost btn-full">Open Issue</a>
        </div>
        
        <div class="sidebar-card card">
          <h4>Contribute</h4>
          <p>Have something similar to share?</p>
          <a href="/submit" class="btn btn-secondary btn-full">Submit Resource</a>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  .resource-detail {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 40px;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .breadcrumb a {
    color: var(--text-secondary);
  }

  .breadcrumb a:hover {
    color: var(--primary);
  }

  .breadcrumb .separator {
    color: var(--border);
  }

  .resource-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 64px;
  }

  .resource-header {
    margin-bottom: 48px;
  }

  .resource-meta-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .resource-date {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .resource-header h1 {
    font-size: 3rem;
    margin-bottom: 16px;
  }

  .resource-description {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 32px;
    max-width: 800px;
  }

  .resource-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-lg {
    padding: 14px 32px;
    font-size: 1.125rem;
  }

  .resource-details-section {
    margin-bottom: 64px;
    padding: 32px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .resource-details-section h3 {
    margin-bottom: 24px;
    font-size: 1.25rem;
  }

  .details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 32px;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .detail-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .author-link {
    color: var(--primary);
    font-weight: 500;
  }

  .tag-list {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 2px 10px;
    background: var(--bg-elevated);
    border-radius: 100px;
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .category-name {
    text-transform: capitalize;
    color: var(--text-primary);
  }

  .related-section h3 {
    margin-bottom: 24px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .related-card h4 {
    margin: 12px 0 8px;
  }

  .related-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .resource-sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sidebar-card h4 {
    margin-bottom: 12px;
  }

  .sidebar-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .btn-full {
    width: 100%;
  }

  @media (max-width: 1024px) {
    .resource-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    
    .resource-sidebar {
      order: -1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .resource-header h1 {
      font-size: 2.25rem;
    }
    
    .resource-sidebar {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const shareBtn = document.querySelector('.share-btn');
  shareBtn?.addEventListener('click', async () => {
    const url = shareBtn.getAttribute('data-url');
    if (navigator.share) {
      try {
        await navigator.share({
          title: document.title,
          url: url
        });
      } catch (err) {}
    } else {
      navigator.clipboard.writeText(url);
      alert('Link copied to clipboard!');
    }
  });
</script>
